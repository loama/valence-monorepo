{
  "name": "valence-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "bun run install:website && bun run install:app && bun run install:admin && bun run install:api && bun run install:database",
    "install:app": "bun install --cwd app",
    "install:admin": "bun install --cwd admin",
    "install:website": "bun install --cwd website",
    "install:api": "bun install --cwd api",
    "install:database": "bun install --cwd database",
    "build": "bun run build:website && bun run build:app && bun run build:admin && bun run build:api && bun run build:database",
    "build:app": "bun run --cwd app build",
    "build:admin": "bun run --cwd admin build",
    "build:website": "bun run --cwd website build",
    "build:api": "bun run --cwd api build",
    "build:database": "bun run --cwd database build",
    "dev": "bun scripts/dev-router.mjs",
    "dev:app": "bun run --cwd app dev",
    "dev:admin": "bun run --cwd admin dev",
    "dev:website": "bun run --cwd website dev",
    "dev:api": "bun run --cwd api dev",
    "android:build": "bun run --cwd app android:build",
    "android:open": "bun run --cwd app android:open",
    "android:sync": "bun run --cwd app android:sync",
    "android:test": "bun run --cwd app android:test",
    "db:generate": "bun run --cwd database db:generate",
    "db:migrate": "bun run --cwd database db:migrate",
    "db:studio": "bun run --cwd database db:studio",
    "start": "node api/dist/server.js",
    "react-doctor:app": "bun scripts/react-doctor-score.mjs app",
    "react-doctor:admin": "bun scripts/react-doctor-score.mjs admin",
    "react-doctor:website": "bun scripts/react-doctor-score.mjs website",
    "heroku-postbuild": "node scripts/heroku-build-api.mjs"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "firebase-admin": "13.10.0"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "24.12.4",
    "typescript": "6.0.3"
  }
}
