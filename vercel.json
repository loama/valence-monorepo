{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "website/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "app/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "admin/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/app/_next/(.*)",
      "dest": "app/_next/$1"
    },
    {
      "src": "/admin/_next/(.*)",
      "dest": "admin/_next/$1"
    },
    {
      "src": "/app(?:/(.*))?",
      "dest": "app"
    },
    {
      "src": "/admin(?:/(.*))?",
      "dest": "admin"
    },
    {
      "src": "/(.*)",
      "dest": "website"
    }
  ]
}
